    "buffer": "^6.0.3",
    "classnames": "^2.2.6",
    "express": "^4.16.4",
    "jquery": "^3.3.1",
    "jsonwebtoken": "^9.0.0",
    "mime-types": "^2.1.26",
    "multer": "^1.4.5-lts.1",
    "next": "9.0.5",
    "qrcode.react": "^0.8.0",
